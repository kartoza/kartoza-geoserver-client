# ============================================================
# Kartoza CloudBench — Environment Variables
# Copy to .env and fill in values before running docker compose
# ============================================================

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# --- Django ---
DJANGO_SETTINGS_MODULE=cloudbench.settings.production
DJANGO_SECRET_KEY=DJANGO_SECRET_KEY
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# --- Nginx ---
HTTP_PORT=80

# --- CloudBench ---
CLOUDBENCH_TAG=0.0.1

# Main data folder (mounted as a volume)
CLOUDBENCH_DATA_FOLDER=/home/web/cloudbench_data

# Encryption key for stored credentials
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUDBENCH_ENCRYPTION_KEY=

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_LOG_LEVEL=info

# --- CORS (production) ---
CORS_ALLOWED_ORIGINS=https://yourdomain.com